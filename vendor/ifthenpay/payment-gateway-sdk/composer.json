{
    "name": "ifthenpay/payment-gateway-sdk",
    "license": "GPL-3.0-or-later",
    "description": "Ifthenpay Payment Gateway SDK for PHP",
    "autoload": {
        "psr-4": {
            "Ifthenpay\\PaymentGateway\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ifthenpay\\PaymentGateway\\Tests\\": "tests/"
        }
    },
    "support": {
        "email": "support@ifthenpay.com"
    },
	"require-dev": {
        "pestphp/pest": "^3.8",
        "laravel/pint": "^1.22",
        "phpstan/phpstan": "^2.1",
        "vlucas/phpdotenv": "^5.6",
        "mockery/mockery": "^1.6",
        "guzzlehttp/guzzle": "^7.10"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "pest",
        "pint": "pint",
        "stan": "phpstan"
    },
    "require": {
        "php": ">=8.1",
        "nyholm/psr7": "^1.8",
        "php-http/curl-client": "^2.3"
    }
}
